<%- include('navbar') %>

<% 
    // Khai báo biến kiểm tra quyền cho code EJS ngắn gọn và dễ đọc hơn
    const isAdmin = (typeof user !== 'undefined' && user.QuyenHan === 'admin'); 
%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0 text-secondary"><i class="fa-solid fa-pen-to-square me-2"></i>Cập nhật Sản phẩm</h4>
    <a href="/laptop" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-5">
        
        <% if (!isAdmin) { %>
            <div class="alert alert-info py-2 mb-4" style="font-size: 0.9rem;">
                <i class="fa-solid fa-circle-info me-1"></i> <strong>Quyền Nhân viên:</strong> Giá nhập khẩu đã được bảo mật. Bạn chỉ được phép cập nhật <b>Số lượng kho</b>.
            </div>
        <% } %>

        <form action="/laptop/sua/<%= laptop._id %>" method="POST">
            <div class="row g-4">
                <div class="col-md-8">
                    <label class="form-label fw-semibold text-muted">Tên sản phẩm</label>
                    <input type="text" class="form-control <%= isAdmin ? 'bg-light' : 'bg-light text-muted' %>" 
                           name="TenLaptop" value="<%= laptop.TenLaptop %>" 
                           <%= isAdmin ? '' : 'readonly' %> required>
                </div>
                
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted">Danh mục / Thương hiệu</label>
                    <select class="form-select <%= isAdmin ? 'bg-light' : 'bg-light text-muted' %>" 
                            name="DanhMuc" <%= isAdmin ? 'required' : 'disabled' %>>
                        <% danhmucList.forEach(dm => { %>
                            <option value="<%= dm._id %>" <%= (dm._id.toString() == laptop.DanhMuc.toString()) ? 'selected' : '' %>>
                                <%= dm.TenDanhMuc %>
                            </option>
                        <% }) %>
                    </select>
                    <% if (!isAdmin) { %>
                        <input type="hidden" name="DanhMuc" value="<%= laptop.DanhMuc %>">
                    <% } %>
                </div>

                <% if (isAdmin) { %>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Giá nhập (VNĐ)</label>
                        <input type="number" class="form-control bg-light" name="GiaNhap" value="<%= laptop.GiaNhap %>" required>
                    </div>
                <% } else { %>
                    <input type="hidden" name="GiaNhap" value="<%= laptop.GiaNhap %>">
                <% } %>

                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted">Giá bán (VNĐ)</label>
                    <input type="number" class="form-control <%= isAdmin ? 'bg-light' : 'bg-light text-muted' %>" 
                           name="GiaBan" value="<%= laptop.GiaBan %>" 
                           <%= isAdmin ? '' : 'readonly' %> required>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold text-primary">Số lượng kho (Được phép sửa)</label>
                    <input type="number" class="form-control border-primary" name="SoLuong" value="<%= laptop.SoLuong %>" required autofocus>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold text-muted">Cấu hình tóm tắt</label>
                    <input type="text" class="form-control <%= isAdmin ? 'bg-light' : 'bg-light text-muted' %>" 
                           name="CauHinh" value="<%= laptop.CauHinh %>" 
                           <%= isAdmin ? '' : 'readonly' %> required>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold text-muted">URL Hình ảnh</label>
                    <input type="text" class="form-control <%= isAdmin ? 'bg-light' : 'bg-light text-muted' %>" 
                           name="HinhAnh" value="<%= laptop.HinhAnh %>" 
                           <%= isAdmin ? '' : 'readonly' %>>
                    <% if(laptop.HinhAnh) { %>
                        <div class="mt-3">
                            <img src="<%= laptop.HinhAnh %>" alt="Ảnh hiện tại" class="rounded border" width="100">
                        </div>
                    <% } %>
                </div>
            </div>
            
            <hr class="my-4 border-secondary opacity-25">
            
            <div class="text-end">
                <a href="/laptop" class="btn btn-light px-4 me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i>Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<%- include('footer') %>
</div> <%- include('javascript') %>
</body>
</html>
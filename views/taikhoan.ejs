<%- include('navbar') %>

<div class="table-wrapper mt-4">
    <h5 class="fw-bold mb-4 text-secondary"><i class="fa-solid fa-users-gear me-2"></i>Danh sách Tài khoản hệ thống</h5>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th>Ảnh</th>
                    <th>Họ Tên / Tên đăng nhập</th>
                    <th>Quyền hiện tại</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u => { %>
                    <tr>
                        <td>
                            <img src="<%= u.HinhAnh ? u.HinhAnh : 'https://ui-avatars.com/api/?name=' + u.HoVaTen %>" 
                                 class="rounded-circle border" width="40" height="40">
                        </td>
                        <td>
                            <div class="fw-bold"><%= u.HoVaTen %></div>
                            <small class="text-muted"><%= u.TenDangNhap %></small>
                        </td>
                        <td>
                            <span class="badge <%= u.QuyenHan === 'admin' ? 'bg-danger' : 'bg-info text-dark' %> rounded-pill px-3">
                                <%= u.QuyenHan.toUpperCase() %>
                            </span>
                        </td>
                        <td class="text-center">
                            <% if (user && user._id.toString() !== u._id.toString()) { %>
                                <form action="/taikhoan/doi-quyen/<%= u._id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm <%= u.QuyenHan === 'admin' ? 'btn-outline-secondary' : 'btn-outline-danger' %> px-3 rounded-pill">
                                        <i class="fa-solid fa-arrows-rotate me-1"></i>
                                        <%= u.QuyenHan === 'admin' ? 'Hạ quyền Staff' : 'Nâng quyền Admin' %>
                                    </button>
                                </form>
                            <% } else { %>
                                <small class="text-muted fst-italic">Tài khoản hiện tại</small>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('footer') %>
</div> <%- include('javascript') %>
</body>
</html>
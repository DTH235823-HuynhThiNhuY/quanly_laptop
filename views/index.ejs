<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Quản Lý Laptop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar {
            height: 100vh;
            background: #2c3e50;
            color: #fff;
            position: fixed;
            width: 250px;
            transition: all 0.3s;
        }
        .sidebar a {
            color: #aeb2b7;
            text-decoration: none;
            padding: 15px 20px;
            display: block;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background: #1a252f;
            color: #fff;
            border-left: 4px solid #3498db;
        }
        .main-content {
            margin-left: 250px;
            padding: 20px;
            transition: all 0.3s;
        }
        .card-stat {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.3s;
        }
        .card-stat:hover {
            transform: translateY(-5px);
        }
        .table-wrapper {
            background: #fff;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        .table th {
            border-top: none;
            color: #7a838b;
            font-weight: 600;
        }
        .table td {
            vertical-align: middle;
        }
        .action-btn {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 5px;
        }
        .product-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column">
        <h4 class="text-center py-4 mb-0 fw-bold border-bottom border-secondary">
            <i class="fa-solid fa-laptop-code me-2 text-info"></i>LaptopPro
        </h4>
        <div class="flex-grow-1 mt-3">
            <a href="#" class="active"><i class="fa-solid fa-gauge me-2"></i> Tổng quan</a>
            <a href="#"><i class="fa-solid fa-laptop me-2"></i> Sản phẩm</a>
            <a href="#"><i class="fa-solid fa-cart-shopping me-2"></i> Đơn hàng</a>
            <a href="#"><i class="fa-solid fa-users me-2"></i> Khách hàng</a>
            <a href="#"><i class="fa-solid fa-chart-line me-2"></i> Thống kê</a>
        </div>
        <div class="mt-auto border-top border-secondary">
            <a href="#"><i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <nav class="navbar navbar-expand-lg navbar-light bg-white rounded-pill px-4 mb-4 shadow-sm">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h1 fw-bold text-secondary">Quản lý Sản phẩm</span>
                <div class="d-flex align-items-center">
                    <div class="input-group me-3">
                        <input type="text" class="form-control rounded-pill bg-light border-0" placeholder="Tìm kiếm laptop...">
                        <button class="btn border-0 position-absolute end-0 z-3" type="button"><i class="fa-solid fa-search text-muted"></i></button>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Admin&background=0D8ABC&color=fff" alt="Admin" class="rounded-circle" width="40">
                </div>
            </div>
        </nav>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card card-stat bg-primary text-white">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tổng Laptops</h6>
                            <h3 class="mb-0"></h3>
                        </div>
                        <i class="fa-solid fa-laptop fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-stat bg-success text-white">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Đang bán</h6>
                            <h3 class="mb-0"></h3>
                        </div>
                        <i class="fa-solid fa-check-circle fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-stat bg-warning text-dark">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Sắp hết hàng</h6>
                            <h3 class="mb-0"></h3>
                        </div>
                        <i class="fa-solid fa-triangle-exclamation fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-stat bg-danger text-white">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Hết hàng</h6>
                            <h3 class="mb-0"></h3>
                        </div>
                        <i class="fa-solid fa-box-open fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-wrapper">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Danh sách Laptop</h5>
                <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addLaptopModal">
                    <i class="fa-solid fa-plus me-1"></i> Thêm mới
                </button>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Sản phẩm</th>
                            <th>Thương hiệu</th>
                            <th>Giá nhập</th>
                            <th>Giá bán</th>
                            <th>Kho</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light p-1 rounded me-2">
                                        <i class="fa-solid fa-computer fa-2x text-secondary"></i>
                                    </div>
                                </div>
                            </td>
                            
                            <td><span class="badge bg-success rounded-pill px-3 py-2">Còn hàng</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-info action-btn"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn btn-sm btn-outline-danger action-btn"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                        <tr>
                            
                            <td><span class="badge bg-warning text-dark rounded-pill px-3 py-2">Sắp hết</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-info action-btn"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn btn-sm btn-outline-danger action-btn"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light p-1 rounded me-2">
                                        <i class="fa-solid fa-computer fa-2x text-secondary"></i>
                                    </div>                                    
                                </div>
                            
                            <td><span class="badge bg-danger rounded-pill px-3 py-2">Hết hàng</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-info action-btn"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn btn-sm btn-outline-danger action-btn"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Sau</a></li>
                </ul>
            </nav>
        </div>
    </div>

    <div class="modal fade" id="addLaptopModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Thêm Laptop Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Tên sản phẩm</label>
                                <input type="text" class="form-control" placeholder="VD: Asus ROG Strix G15">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Thương hiệu</label>
                                <select class="form-select">
                                    <option selected>Chọn thương hiệu...</option>
                                    <option value="1">Asus</option>
                                    <option value="2">Dell</option>
                                    <option value="3">HP</option>
                                    <option value="4">Lenovo</option>
                                    
                                    
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Giá nhập (VNĐ)</label>
                                <input type="number" class="form-control" placeholder="0">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Giá bán (VNĐ)</label>
                                <input type="number" class="form-control" placeholder="0">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Số lượng kho</label>
                                <input type="number" class="form-control" placeholder="0">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Cấu hình tóm tắt</label>
                                <input type="text" class="form-control" placeholder="VD: Core i7 12700H, RAM 16GB, SSD 512GB, RTX 3060">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary px-4">Lưu sản phẩm</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
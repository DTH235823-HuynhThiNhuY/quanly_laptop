<%- include('navbar') %>

<div class="mt-2">
    <h4 class="fw-bold text-secondary mb-4"><i class="fa-solid fa-chart-pie me-2"></i> Báo cáo Thống kê</h4>

    <div class="row mb-4">
        
        <% if (typeof user !== 'undefined' && user !== null && user.QuyenHan === 'admin') { %>
            <div class="col-md-4">
                <div class="card card-stat bg-success text-white">
                    <div class="card-body d-flex justify-content-between align-items-center p-4">
                        <div>
                            <h6 class="card-title text-uppercase fw-semibold opacity-75">Tổng Doanh Thu</h6>
                            <h3 class="mb-0 fw-bold"><%= stats.doanhThu.toLocaleString('vi-VN') %> ₫</h3>
                            <small class="opacity-75">Từ các đơn đã hoàn thành</small>
                        </div>
                        <i class="fa-solid fa-sack-dollar fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        <% } %>

        <div class="<%= (typeof user !== 'undefined' && user.QuyenHan === 'admin') ? 'col-md-4' : 'col-md-6' %>">
            <div class="card card-stat bg-primary text-white">
                <div class="card-body d-flex justify-content-between align-items-center p-4">
                    <div>
                        <h6 class="card-title text-uppercase fw-semibold opacity-75">Tổng Đơn Hàng</h6>
                        <h3 class="mb-0 fw-bold"><%= stats.tongDonHang %> Đơn</h3>
                        <small class="opacity-75">Tất cả trạng thái</small>
                    </div>
                    <i class="fa-solid fa-cart-flatbed fa-3x opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="<%= (typeof user !== 'undefined' && user.QuyenHan === 'admin') ? 'col-md-4' : 'col-md-6' %>">
            <div class="card card-stat bg-info text-white">
                <div class="card-body d-flex justify-content-between align-items-center p-4">
                    <div>
                        <h6 class="card-title text-uppercase fw-semibold opacity-75">Chờ Xác Nhận</h6>
                        <h3 class="mb-0 fw-bold"><%= stats.donChoXacNhan %> Đơn</h3>
                        <small class="opacity-75">Cần xử lý ngay</small>
                    </div>
                    <i class="fa-solid fa-bell fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold text-secondary mb-3 mt-5"><i class="fa-solid fa-warehouse me-2"></i> Trạng thái Kho hàng</h5>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card card-stat bg-secondary text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Mẫu Laptop</h6>
                        <h3 class="mb-0"><%= stats.tongSoMauLaptop %></h3>
                    </div>
                    <i class="fa-solid fa-laptop fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat bg-dark text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Tổng Tồn Kho</h6>
                        <h3 class="mb-0"><%= stats.tongTonKho %></h3>
                    </div>
                    <i class="fa-solid fa-boxes-stacked fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat bg-warning text-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Sắp Hết Hàng</h6>
                        <h3 class="mb-0"><%= stats.sapHetHang %></h3>
                    </div>
                    <i class="fa-solid fa-triangle-exclamation fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat bg-danger text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Đã Hết Hàng</h6>
                        <h3 class="mb-0"><%= stats.hetHang %></h3>
                    </div>
                    <i class="fa-solid fa-box-open fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>
</div>
<%- include('javascript') %>
</body>
</html>
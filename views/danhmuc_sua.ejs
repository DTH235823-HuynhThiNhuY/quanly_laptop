<%- include('navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0 text-secondary"><i class="fa-solid fa-pen-to-square me-2"></i>Sửa thông tin Hãng</h4>
    <a href="/danhmuc" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="card shadow-sm border-0 rounded-4" style="max-width: 600px; margin: 0 auto;">
    <div class="card-body p-5">
        <form action="/danhmuc/sua/<%= danhmuc._id %>" method="POST">
            <div class="mb-4">
                <label class="form-label fw-semibold text-muted">Tên hãng</label>
                <input type="text" class="form-control bg-light" name="TenDanhMuc" value="<%= danhmuc.TenDanhMuc %>" required autofocus>
            </div>
            
            <hr class="my-4 border-secondary opacity-25">
            
            <div class="text-end">
                <a href="/danhmuc" class="btn btn-light px-4 me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i>Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<%- include('footer') %>
</div>
<%- include('javascript') %>
</body>
</html>
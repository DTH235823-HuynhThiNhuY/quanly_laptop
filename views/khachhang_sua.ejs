<%- include('navbar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0 text-secondary"><i class="fa-solid fa-pen-to-square me-2"></i>Cập nhật Khách Hàng</h4>
    <a href="/khachhang" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="card shadow-sm border-0 rounded-4" style="max-width: 600px; margin: 0 auto;">
    <div class="card-body p-5">
        <form action="/khachhang/sua/<%= khachhang._id %>" method="POST">
            <div class="mb-3">
                <label class="form-label fw-bold">Họ và tên</label>
                <input type="text" class="form-control bg-light" name="HoTen" value="<%= khachhang.HoTen %>" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Số điện thoại</label>
                <input type="text" class="form-control bg-light" name="SoDienThoai" value="<%= khachhang.SoDienThoai %>" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input type="email" class="form-control bg-light" name="Email" value="<%= khachhang.Email %>">
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Địa chỉ</label>
                <input type="text" class="form-control bg-light" name="DiaChi" value="<%= khachhang.DiaChi %>">
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold">Ghi chú</label>
                <textarea class="form-control bg-light" name="GhiChu" rows="3"><%= khachhang.GhiChu %></textarea>
            </div>
            
            <hr class="my-4 border-secondary opacity-25">
            
            <div class="text-end">
                <a href="/khachhang" class="btn btn-light px-4 me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i>Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<%- include('footer') %>
</div>
<%- include('javascript') %>
</body>
</html>